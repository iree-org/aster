# REQUIRES: stinkytofu-opt
# RUN: stinkytofu-opt --arch gfx1250 %s --print-output | FileCheck %s
# CHECK-LABEL: st.func @roundtrip_minimal()
# CHECK: ^entry:
# CHECK: v0 = "st.v_add_f32"(v1, v2)
# CHECK: v3 = "st.v_mul_f32"(v0, v4)
# CHECK: v5 = "st.v_add_f32"(v3, v0)
st.func @roundtrip_minimal() {
^entry:
  v0 = "st.v_add_f32"(v1, v2) { issueCycles = 1, latencyCycles = 5 }
  v3 = "st.v_mul_f32"(v0, v4) { issueCycles = 1, latencyCycles = 5 }
  v5 = "st.v_add_f32"(v3, v0) { issueCycles = 1, latencyCycles = 5 }
}
