Pattern SAddI64 {
  let dst: Value;
  let lhs: Value;
  let rhs: Value;
  IsSGPRRange(dst, attr<"2">);
  IsSGPRRange(lhs, attr<"2">);
  IsSGPRRange(rhs, attr<"2">);
  let root = op<pir.addi>(dst, lhs, rhs) {semantics = attr<"i64">};
