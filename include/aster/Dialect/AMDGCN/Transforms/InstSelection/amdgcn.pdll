//===----------------------------------------------------------------------===//
// pir.muli patterns.
//===----------------------------------------------------------------------===//

Pattern VMulI16 {
  let dst: [Value, IsVGPR];
  let lhs: [Value, IsGPR];
  let rhs: [Value, IsVGPR];
  let resultTypes: TypeRange;
  let root = op<pir.muli>(dst, lhs, rhs) {semantics = attr<"i16">} -> (resultTypes);
  rewrite root with {
    let opcode: Attr = get_opcode(attr<"\"v_mul_lo_u16\"">);
    let result = op<amdgcn.vop2>(dst, lhs, rhs) {opcode = opcode, operandSegmentSizes = attr<"array<i32: 1, 0, 1, 1, 0>">} -> (resultTypes);
    replace root with result;
  };
}

Pattern VMulI32 {
  let dst: [Value, IsVGPR];
  let lhs: [Value, IsGPR];
  let rhs: [Value, IsVGPR];
  let resultTypes: TypeRange;
  let root = op<pir.muli>(dst, lhs, rhs) {semantics = attr<"i32">} -> (resultTypes);
  rewrite root with {
    let opcode: Attr = get_opcode(attr<"\"v_mul_lo_u32\"">);
    let result = op<amdgcn.vop3>(dst, lhs, rhs) {opcode = opcode, operandSegmentSizes = attr<"array<i32: 1, 0, 1, 1, 0>">} -> (resultTypes);
    replace root with result;
  };
}

Pattern VMulI64 {
  let dst: Value;
  let lhs: Value;
  let rhs: Value;
  IsVGPRRange(dst, attr<"2">);
  IsGPRRange(lhs, attr<"2">);
  IsGPRRange(rhs, attr<"2">);
  let root = op<pir.muli>(dst, lhs, rhs) {semantics = attr<"i64">};
  rewrite root with {
    let lhsP: ValueRange = split_range((lhs));
    let rhsP: ValueRange = split_range((rhs));
    let dstType: Type = get_reg(attr<"\"VGPR\"">, attr<"1">);
    let lLo: Value = get_value(lhsP, attr<"0">);
    let rLo: Value = get_value(rhsP, attr<"0">);
    let lHi: Value = get_value(lhsP, attr<"1">);
    let rHi: Value = get_value(rhsP, attr<"1">);
    let tmp: Value = make_alloca(dst, get_reg(attr<"\"VGPR\"">, attr<"1">));
    let carry: Value = make_alloca(dst, get_reg(attr<"\"SGPR\"">, attr<"2">));
    let t0 = op<amdgcn.vop3>(rHi, rHi, lLo)
      {opcode = get_opcode(attr<"\"v_mul_lo_u32\"">), operandSegmentSizes = attr<"array<i32: 1, 0, 1, 1, 0>">} -> (dstType);
    let t1 = op<amdgcn.vop3>(tmp, rLo, lHi)
      {opcode = get_opcode(attr<"\"v_mul_lo_u32\"">), operandSegmentSizes = attr<"array<i32: 1, 0, 1, 1, 0>">} -> (dstType);
    let t2 = op<amdgcn.vop3>(dst, carry, rLo, lLo, constant(lLo, attr<"0 : i32">))
      {opcode = get_opcode(attr<"\"v_mad_u64_u32\"">), operandSegmentSizes = attr<"array<i32: 1, 1, 1, 1, 1>">} -> (get_type(dst), get_type(carry));
    let dstP: ValueRange = split_range((t2.0));
    let t3 = op<amdgcn.vop3>(get_value(dstP, attr<"1">), get_value(dstP, attr<"1">), tmp, t0.0)
      {opcode = get_opcode(attr<"\"v_add3_u32\"">), operandSegmentSizes = attr<"array<i32: 1, 0, 1, 1, 1>">} -> (dstType);
    let result = make_range((get_value(dstP, attr<"0">), t3.0));
    replace root with result;
  };
}

Pattern SMulI8 {
  let dst: [Value, IsSGPR];
  let lhs: [Value, IsSGPR];
  let rhs: [Value, IsSGPR];
  let resultTypes: TypeRange;
  let root = op<pir.muli>(dst, lhs, rhs) {semantics = attr<"i8">} -> (resultTypes);
  rewrite root with {
    let opcode: Attr = get_opcode(attr<"\"s_mul_i32\"">);
    let result = op<amdgcn.sop2>(dst, lhs, rhs) {opcode = opcode} -> (resultTypes);
    // TODO: Mask the result to 8 bits.
    replace root with result;
  };
}

Pattern SMulI16 {
  let dst: [Value, IsSGPR];
  let lhs: [Value, IsSGPR];
  let rhs: [Value, IsSGPR];
  let resultTypes: TypeRange;
  let root = op<pir.muli>(dst, lhs, rhs) {semantics = attr<"i16">} -> (resultTypes);
