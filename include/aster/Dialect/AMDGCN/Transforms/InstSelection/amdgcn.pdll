Pattern SMulI32 {
  let dst: [Value, IsSGPR];
  let lhs: [Value, IsSGPR];
  let rhs: [Value, IsSGPR];
  let resultTypes: TypeRange;
  let root = op<pir.muli>(dst, lhs, rhs) {semantics = attr<"i32">} -> (resultTypes);
  rewrite root with {
    let opcode: Attr = get_opcode(attr<"\"s_mul_i32\"">);
    let result = op<amdgcn.sop2>(dst, lhs, rhs) {opcode = opcode} -> (resultTypes);
    replace root with result;
  };
}

Pattern SMulI64 {
  let dst: Value;
  let lhs: Value;
  let rhs: Value;
  IsSGPRRange(dst, attr<"2">);
  IsSGPRRange(lhs, attr<"2">);
  IsSGPRRange(rhs, attr<"2">);
  let root = op<pir.muli>(dst, lhs, rhs) {semantics = attr<"i64">};
  rewrite root with {
    let lhsP: ValueRange = split_range((lhs));
    let rhsP: ValueRange = split_range((rhs));
    let dstP: ValueRange = split_range((dst));
    let dstType: Type = get_type(get_value(dstP, attr<"0">));
    let dLo: Value = get_value(dstP, attr<"0">);
    let lLo: Value = get_value(lhsP, attr<"0">);
    let rLo: Value = get_value(rhsP, attr<"0">);
    let dHi: Value = get_value(dstP, attr<"1">);
    let lHi: Value = get_value(lhsP, attr<"1">);
    let rHi: Value = get_value(rhsP, attr<"1">);
    let t1 = op<amdgcn.sop2>(lHi, rLo, lHi)
      {opcode = get_opcode(attr<"\"s_mul_i32\"">)} -> (dstType);
    let t2 = op<amdgcn.sop2>(dLo, rLo, lLo)
      {opcode = get_opcode(attr<"\"s_mul_hi_u32\"">)} -> (dstType);
    let t3 = op<amdgcn.sop2>(rHi, rHi, lLo)
      {opcode = get_opcode(attr<"\"s_mul_i32\"">)} -> (dstType);
    let t4 = op<amdgcn.sop2>(t1.0, t2.0, t1.0)
      {opcode = get_opcode(attr<"\"s_add_i32\"">)} -> (dstType);
    let t5 = op<amdgcn.sop2>(dLo, rLo, lLo)
      {opcode = get_opcode(attr<"\"s_mul_i32\"">)} -> (dstType);
    let t6 = op<amdgcn.sop2>(dHi, t4.0, t3.0)
      {opcode = get_opcode(attr<"\"s_add_i32\"">)} -> (dstType);
    let result = make_range((t5.0, t6.0));
    replace root with result;
  };
}
