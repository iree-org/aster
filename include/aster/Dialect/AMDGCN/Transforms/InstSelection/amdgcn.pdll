#include "aster/Dialect/PIR/IR/PIROps.td"

//===----------------------------------------------------------------------===//
// Helpers to check register types.
//===----------------------------------------------------------------------===//
Constraint IsAGPR(value: Value);
Constraint IsSGPR(value: Value);
Constraint IsVGPR(value: Value);
Constraint IsGPR(value: Value);

Constraint IsAGPRRange(value: Value, size: Attr);
Constraint IsSGPRRange(value: Value, size: Attr);
Constraint IsVGPRRange(value: Value, size: Attr);
Constraint IsGPRRange(value: Value, size: Attr);

//===----------------------------------------------------------------------===//
// Rewrite helpers.
//===----------------------------------------------------------------------===//

// Helper to get the type of a value.
Rewrite get_type(value: Value) -> Type;
// Helper to get a value from a value range at given index.
Rewrite get_value(value: ValueRange, index: Attr) -> Value;

// Helper to get the opcode attribute for an instruction.
Rewrite get_opcode(opcode: Attr) -> Attr;

// Helper to create alloca instruction.
Rewrite get_reg(kind: Attr, size: Attr) -> Type;

// Helper to create alloca instruction.
Rewrite make_alloca(value: Value, type: Type) -> Value;

// Helper to creare a range allocation.
Rewrite make_range(value: ValueRange) -> Value;
// Helper to split a range value into its components.
Rewrite split_range(value: ValueRange) -> ValueRange;

// Helper to create constant value.
Rewrite constant(locV : Value, value: Attr) -> Value;

//===----------------------------------------------------------------------===//
// Patterns.
//===----------------------------------------------------------------------===//

//===----------------------------------------------------------------------===//
// pir.addi patterns.
//===----------------------------------------------------------------------===//

Pattern VAddI16 {
  let dst: [Value, IsVGPR];
  let lhs: [Value, IsGPR];
  let rhs: [Value, IsVGPR];
  let resultTypes: TypeRange;
  let root = op<pir.addi>(dst, lhs, rhs) {semantics = attr<"i16">} -> (resultTypes);
  rewrite root with {
    let opcode: Attr = get_opcode(attr<"\"v_add_u16\"">);
    let result = op<amdgcn.vop2>(dst, lhs, rhs) {opcode = opcode, operandSegmentSizes = attr<"array<i32: 1, 0, 1, 1, 0>">} -> (resultTypes);
    replace root with result;
  };
}

Pattern VAddI32 {
  let dst: [Value, IsVGPR];
  let lhs: [Value, IsGPR];
  let rhs: [Value, IsVGPR];
  let resultTypes: TypeRange;
  let root = op<pir.addi>(dst, lhs, rhs) {semantics = attr<"i32">} -> (resultTypes);
  rewrite root with {
    let opcode: Attr = get_opcode(attr<"\"v_add_u32\"">);
    let result = op<amdgcn.vop2>(dst, lhs, rhs) {opcode = opcode, operandSegmentSizes = attr<"array<i32: 1, 0, 1, 1, 0>">} -> (resultTypes);
    replace root with result;
  };
}

Pattern VAddI64 {
  let dst: Value;
  let lhs: Value;
  let rhs: Value;
  IsVGPRRange(dst, attr<"2">);
  IsGPRRange(lhs, attr<"2">);
  IsVGPRRange(rhs, attr<"2">);
  let root = op<pir.addi>(dst, lhs, rhs) {semantics = attr<"i64">};
  rewrite root with {
    let carry: Value = make_alloca(dst, get_reg(attr<"\"SGPR\"">, attr<"2">));
    let lhsP: ValueRange = split_range((lhs));
    let rhsP: ValueRange = split_range((rhs));
    let dstP: ValueRange = split_range((dst));
    let dstType: Type = get_type(get_value(dstP, attr<"0">));
    let lo = op<amdgcn.vop2>(get_value(dstP, attr<"0">), carry, get_value(lhsP, attr<"0">), get_value(rhsP, attr<"0">))
      {opcode = get_opcode(attr<"\"v_add_co_u32\"">), operandSegmentSizes = attr<"array<i32: 1, 1, 1, 1, 0>">} -> (dstType, get_type(carry));
    let hi = op<amdgcn.vop2>(get_value(dstP, attr<"1">), carry, get_value(lhsP, attr<"1">), get_value(rhsP, attr<"1">), carry)
      {opcode = get_opcode(attr<"\"v_addc_co_u32\"">), operandSegmentSizes = attr<"array<i32: 1, 1, 1, 1, 1>">} -> (dstType, get_type(carry));
    let result = make_range((lo.0, hi.0));
    replace root with result;
  };
}

Pattern VAddI64_O3 with benefit(10) {
  let dstType: Type;
  let dst: Value<dstType>;
  let lhs: Value;
  let rhs: Value;
  IsVGPRRange(dst, attr<"2">);
  IsGPRRange(lhs, attr<"2">);
  IsGPRRange(rhs, attr<"2">);
  let root = op<pir.addi>(dst, lhs, rhs) {semantics = attr<"i64">};
  rewrite root with {
    let result = op<amdgcn.vop3>(dst, lhs, constant(dst, attr<"0 : i32">), rhs)
      {opcode = get_opcode(attr<"\"v_lshl_add_u64\"">), operandSegmentSizes = attr<"array<i32: 1, 0, 1, 1, 1>">} -> (dstType);
    replace root with result;
  };
}

Pattern SAddI8 {
  let dst: [Value, IsSGPR];
  let lhs: [Value, IsSGPR];
  let rhs: [Value, IsSGPR];
  let resultTypes: TypeRange;
  let root = op<pir.addi>(dst, lhs, rhs) {semantics = attr<"i8">} -> (resultTypes);
  rewrite root with {
    let opcode: Attr = get_opcode(attr<"\"s_add_i32\"">);
    let result = op<amdgcn.sop2>(dst, lhs, rhs) {opcode = opcode} -> (resultTypes);
    // TODO: Mask the result to 8 bits.
    replace root with result;
  };
}

