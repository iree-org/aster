    let hi = op<amdgcn.sop2>(get_value(dstP, attr<"1">), get_value(lhsP, attr<"1">), get_value(rhsP, attr<"1">))
      {opcode = get_opcode(attr<"\"s_addc_u32\"">)} -> (dstType);
    let result = make_range((lo.0, hi.0));
    replace root with result;
  };
}

